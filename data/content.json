  "about": {
    "heading": "Welcome to Seventeen",
    "paragraphs": [
      "Seventeen Cafe is Sun Valley's go-to spot for artisan coffee and homemade bites. We believe great mornings start with great coffee — and we've been crafting the perfect cup for our community, one pour at a time.",
      "From rich espresso drinks to refreshing cold brews, everything on our menu is made with care using locally roasted beans. Drop by for a quick pick-me-up or settle in with a book — you're always welcome here."
    ]
  },
  "services": [
    {
      "title": "Espresso & Lattes",
      "description": "Classic shots, silky lattes, and flavored espresso drinks made with freshly roasted beans. Try our signature vanilla oat milk latte — a customer favorite.",
      "icon": "Coffee"
    },
    {
      "title": "Cold Brew & Iced Drinks",
      "description": "Slow-steeped cold brew served over ice, plus refreshing iced teas and seasonal fruit blends. Perfect for those warm Sun Valley afternoons.",
      "icon": "GlassWater"
    },
    {
      "title": "Fresh Pastries & Bites",
      "description": "Flaky croissants, buttery muffins, and hearty breakfast sandwiches baked fresh every morning. Pair with any coffee for the ultimate breakfast combo.",
      "icon": "Croissant"
    },
    {
      "title": "Specialty Drinks",
      "description": "Matcha lattes, chai tea, hot chocolate, and rotating seasonal specials. There's always something new to try at Seventeen.",
      "icon": "Sparkles"
    }
  ],
